{
  "info": {
    "name": "Mobile Restaurant API",
    "description": "Collection test API EXEprj Backend (đồng bộ OpenAPI 1.1.0).\n\n## Cách dùng\n1. Import file này vào Postman\n2. `baseUrl`: `http://localhost:5000/api` — chạy `npm run dev` + MongoDB\n3. Chạy **Flow — E2E đầy đủ** theo thứ tự (Collection Runner)\n4. Token tự lưu: `ownerToken`, `customerToken`, `adminToken`\n\n## Admin\nAPI không đăng ký được role `admin`. Tạo user admin trong DB (hoặc đổi role), rồi set `adminEmail` / `adminPassword` trong Variables và chạy **Auth → Login Admin**.\n\n## Lưu ý\n- Đơn hàng chỉ tạo được khi nhà hàng `approved` (bước Approve trong Flow)\n- Swagger: http://localhost:5000/api-docs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "ownerToken", "value": "" },
    { "key": "customerToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "restaurantId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "foodId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "notificationId", "value": "" },
    { "key": "driverId", "value": "" },
    { "key": "resetToken", "value": "" },
    { "key": "comboId", "value": "" },
    { "key": "adminEmail", "value": "admin@test.com" },
    { "key": "adminPassword", "value": "password123" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const url = pm.request.url.toString();",
          "const isPublic = url.includes('/health') || url.includes('/auth/register') || url.includes('/auth/login') || url.includes('/auth/refresh') || url.includes('/auth/forgot') || url.includes('/auth/reset') || url.includes('/restaurants/nearby') || url.includes('/payments/momo') || (url.includes('/reviews/') && pm.request.method === 'GET');",
          "const isPublicGet = pm.request.method === 'GET' && (url.match(/\\/restaurants\\/[^/]+$/) && !url.includes('/owner/') || (url.includes('/menu/') && url.includes('/categories') || url.includes('/foods') || url.includes('/combos') || url.includes('/promotions')));",
          "if (isPublic || isPublicGet) {",
          "  return;",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Flow — E2E đầy đủ",
      "description": "Chạy Collection Runner trên folder này theo thứ tự. Cần MongoDB + server. Bước Login Admin cần tài khoản admin trong DB (xem mô tả collection).",
      "item": [
        {
          "name": "01 Health",
          "request": { "auth": { "type": "noauth" }, "method": "GET", "url": "{{baseUrl}}/health" },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Health 200', () => pm.response.to.have.status(200));"] } }]
        },
        {
          "name": "02 Register Owner",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Owner Flow\",\n  \"email\": \"owner.flow@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"restaurant_owner\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();","if (r.data?.accessToken) {","  pm.collectionVariables.set('ownerToken', r.data.accessToken);","  pm.collectionVariables.set('accessToken', r.data.accessToken);","  pm.collectionVariables.set('refreshToken', r.data.refreshToken);","}","pm.test('Register owner', () => pm.expect([201,400]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "03 Register Customer",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"fullName\": \"Customer Flow\",\n  \"email\": \"customer.flow@test.com\",\n  \"password\": \"password123\",\n  \"role\": \"customer\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();","if (r.data?.accessToken) pm.collectionVariables.set('customerToken', r.data.accessToken);","pm.test('Register customer', () => pm.expect([201,400]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "04 Create Restaurant",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{ownerToken}}" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Nha Hang Flow\",\n  \"description\": \"Test restaurant\",\n  \"phone\": \"0901234567\",\n  \"address\": \"123 Nguyen Hue, Q1, HCM\",\n  \"latitude\": 10.762622,\n  \"longitude\": 106.660172\n}" },
            "url": "{{baseUrl}}/restaurants"
          },
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();","if (r.data?._id) pm.collectionVariables.set('restaurantId', r.data._id);","pm.test('Create restaurant', () => pm.expect([201,403]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "05 Login Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();","if (r.data?.accessToken) pm.collectionVariables.set('adminToken', r.data.accessToken);","pm.test('Admin login', () => pm.expect([200,401]).to.include(pm.response.code));"] } }]
        },
        {
          "name": "06 Approve Restaurant",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}" }] },
            "method": "PATCH",
            "url": "{{baseUrl}}/restaurants/{{restaurantId}}/approve"
          },
          "event": [{ "listen": "test", "script": { "exec": ["pm.test('Approve restaurant', () => pm.expect([200,403,404]).to.include(pm.response.code));"] } }]
        },
