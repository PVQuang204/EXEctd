            "body": { "mode": "raw", "raw": "{\n  \"restaurantId\": \"{{restaurantId}}\",\n  \"items\": [{ \"foodId\": \"{{foodId}}\", \"quantity\": 2 }],\n  \"deliveryAddress\": \"456 Le Loi, Q1, HCM\",\n  \"deliveryLocation\": { \"type\": \"Point\", \"coordinates\": [106.661, 10.763] },\n  \"note\": \"It nong\",\n  \"promotionCode\": \"FLOW10\"\n}" },
