          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();","if (r.data?.accessToken) pm.collectionVariables.set('customerToken', r.data.accessToken);","pm.test('Login customer', () => pm.response.to.have.status(200));"] } }]
