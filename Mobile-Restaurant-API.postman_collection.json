          "event": [{ "listen": "test", "script": { "exec": ["const r = pm.response.json();","if (r.data?._id) pm.collectionVariables.set('categoryId', r.data._id);","pm.test('Create category', () => pm.expect([201,403]).to.include(pm.response.code));"] } }]
