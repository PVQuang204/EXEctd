NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/mobile-restaurant?retryWrites=true&w=majority

# JWT (JWT_SECRET cũ vẫn được hỗ trợ làm ACCESS secret)
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
# Legacy alias:
# JWT_SECRET=your-access-secret-min-32-chars

# MongoDB (MONGO_URI cũng được hỗ trợ)
# MONGODB_URI=mongodb+srv://...

# Email (Forgot Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Mobile Restaurant <noreply@restaurant.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PayOS Payment Gateway
PAYOS_CLIENT_ID=your-payos-client-id
PAYOS_API_KEY=your-payos-api-key
PAYOS_CHECKSUM_KEY=your-payos-checksum-key

# Frontend URL (CORS + email reset link)
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:5000
