{
  "name": "mobile-restaurant-api",
  "version": "1.0.0",
  "description": "Mobile Restaurant Management System - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand",
    "test:unit": "jest --testPathPattern=unit --coverage",
    "test:integration": "jest --testPathPattern=integration --runInBand --coverage",
    "test:requirements": "jest src/tests/e2e/full-requirements.test.js --runInBand --verbose",
    "test:all": "node test-all-features.js"
  },
  "keywords": ["restaurant", "express", "mongodb", "socket.io"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^2.0.0",
    "nodemailer": "^6.9.15",
    "socket.io": "^4.8.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.12.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.2",
    "nodemon": "^3.1.7",
    "socket.io-client": "^4.8.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": ["<rootDir>/src/tests"],
    "collectCoverageFrom": [
      "src/services/**/*.js",
      "!src/services/upload.service.js",
      "src/config/env.js",
      "src/repositories/**/*.js",
      "src/utils/**/*.js",
      "src/middleware/**/*.js",
      "src/config/vnpay.js",
      "src/models/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 25,
        "functions": 60,
        "lines": 55,
        "statements": 55
      }
    },
    "setupFilesAfterEnv": ["<rootDir>/src/tests/setup.js"],
    "testTimeout": 30000
  }
}
